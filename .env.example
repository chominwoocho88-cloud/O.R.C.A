# Required for ORCA live run and ORCA backtest
ANTHROPIC_API_KEY=

# Optional ORCA model overrides
ORCA_MODE=MORNING
ORCA_MODEL=claude-sonnet-4-6
ORCA_MODEL_HUNTER=claude-haiku-4-5-20251001
ORCA_MODEL_LITE=claude-sonnet-4-6

# Optional JACKAL model override
SUBAGENT_MODEL=claude-haiku-4-5-20251001

# Optional market-data providers
FRED_API_KEY=
KRX_API_KEY=
FSCAPI_KEY=

# Optional delivery / runtime flags
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
KIS_CONNECTED=false
